{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI — API Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["api.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Streamlit — Dashboard",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "app.py", "--server.port", "8501"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Pipeline — Full Run",
      "type": "debugpy",
      "request": "launch",
      "module": "backend.pipeline",
      "args": ["--skip-fetch"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Fetch News Only",
      "type": "debugpy",
      "request": "launch",
      "module": "backend.fetch_news",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ],
  "compounds": [
    {
      "name": "🚀 Full Stack (API + Dashboard)",
      "configurations": ["FastAPI — API Server", "Streamlit — Dashboard"]
    }
  ]
}
